generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  password     String
  name         String
  role         String     @default("USER")
  isActive     Boolean    @default(true)
  lastLogin    DateTime?
  profileImage String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  blogPosts    BlogPost[]
  likes        Like[]
  savedVerses  SavedVerse[]
  prayerRequests PrayerRequest[]
  prayerSupports PrayerSupport[]
  forumTopics    ForumTopic[]
  forumPosts     ForumPost[]
  devotionals    Devotional[]   @relation("DevotionalAuthor")
  createdEvents  Event[]        @relation("EventAuthor")
  rsvps         Event[]        @relation("EventRSVPs")
  notifications Notification[]
  viewHistory  ViewHistory[]
  receiveNewsletter   Boolean    @default(true)
  receivePrayerAlerts Boolean    @default(true)

  @@map("users")
}

model ViewHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // 'POST', 'FORUM', 'DEVOTIONAL'
  itemId    String   // The ID of the item viewed
  title     String
  link      String
  viewedAt  DateTime @default(now())

  @@index([userId, viewedAt])
  @@map("view_history")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // 'FORUM_REPLY', 'EVENT_UPDATE', 'PRAYER_SUPPORT', 'ADMIN_MESSAGE'
  title     String
  message   String
  link      String?  // URL to redirect when clicked
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notifications")
}

// ... existing models ...

model Devotional {
  id                 String   @id @default(uuid())
  date               DateTime @unique // The specific day this devotional is for
  title              String
  content            String
  scripture          String
  reflectionQuestions String?
  authorId           String
  author             User     @relation("DevotionalAuthor", fields: [authorId], references: [id])
  comments           Comment[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("devotionals")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  date        DateTime
  location    String   // Physical address or online link
  type        String   // STUDY, WORSHIP, COMMUNITY, YOUTH
  thumbnail   String?
  authorId    String
  author      User     @relation("EventAuthor", fields: [authorId], references: [id])
  rsvps       User[]   @relation("EventRSVPs")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("events")
}

model ForumCategory {
  id          String       @id @default(cuid())
  name        String
  description String?
  icon        String?      // Lucide icon name or emoji
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  topics      ForumTopic[]

  @@map("forum_categories")
}

model ForumTopic {
  id         String      @id @default(cuid())
  categoryId String
  authorId   String
  title      String
  content    String
  isLocked   Boolean     @default(false)
  isSticky   Boolean     @default(false)
  views      Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  category   ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  author     User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  posts      ForumPost[]

  @@index([categoryId])
  @@index([authorId])
  @@index([createdAt])
  @@map("forum_topics")
}

model ForumPost {
  id        String     @id @default(cuid())
  topicId   String
  authorId  String
  content   String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  topic     ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([topicId])
  @@index([authorId])
  @@index([createdAt])
  @@map("forum_posts")
}


model PrayerRequest {
  id           String          @id @default(cuid())
  userId       String
  title        String
  content      String
  category     String          @default("GENERAL") // HEALING, FAMILY, GUIDANCE, THANKSGIVING, etc.
  isAnonymous  Boolean         @default(false)
  status       String          @default("ACTIVE")    // ACTIVE, ANSWERED, ARCHIVED
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  supports     PrayerSupport[]

  @@index([userId])
  @@index([status, createdAt])
  @@index([category])
  @@map("prayer_requests")
}

model PrayerSupport {
  id              String        @id @default(cuid())
  userId          String
  prayerRequestId String
  createdAt       DateTime      @default(now())
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  prayerRequest   PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)

  @@unique([userId, prayerRequestId])
  @@map("prayer_supports")
}

model BlogPost {
  id             String     @id @default(cuid())
  title          String
  slug           String     @unique
  excerpt        String
  content        String
  featuredImage  String
  authorId       String
  category       String     @default("OTHER")
  tags           String?
  status         String     @default("DRAFT")
  publishedAt    DateTime?
  readTime       Int        @default(5)
  views          Int        @default(0)
  likes          Int        @default(0)
  isFeatured     Boolean    @default(false)
  isPremium      Boolean    @default(false)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  author         User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments       Comment[]
  userLikes      Like[]

  @@index([slug])
  @@index([status, publishedAt])
  @@index([category])
  @@map("blog_posts")
}

model Contact {
  id           String    @id @default(cuid())
  name         String
  email        String
  subject      String
  message      String
  status       String    @default("NEW")
  isRead       Boolean   @default(false)
  repliedAt    DateTime?
  replyMessage String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status, createdAt])
  @@map("contacts")
}

model Donation {
  id            String   @id @default(cuid())
  donorName     String
  email         String
  amount        Float
  currency      String   @default("USD")
  paymentMethod String   @default("STRIPE")
  paymentId     String
  status        String   @default("PENDING")
  message       String?
  isAnonymous   Boolean  @default(false)
  receiptSent   Boolean  @default(false)
  receiptEmail  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, createdAt])
  @@index([email])
  @@map("donations")
}

model Comment {
  id          String   @id @default(cuid())
  content     String
  authorName  String
  authorEmail String
  postId      String?
  devotionalId String?
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  post        BlogPost? @relation(fields: [postId], references: [id], onDelete: Cascade)
  devotional  Devotional? @relation(fields: [devotionalId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([devotionalId, createdAt])
  @@index([isApproved])
  @@map("comments")
}

model BibleVerse {
  id            String          @id @default(cuid())
  title         String?
  book          String
  chapter       Int
  verse         Int
  text          String
  translation   String          @default("NIV")
  image         String?
  isActive      Boolean         @default(true)
  isFeatured    Boolean         @default(false)
  shareCount    Int             @default(0)
  displayDate   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  verseOfTheDay VerseOfTheDay[]
  shares        VerseShare[]
  savedBy       SavedVerse[]

  @@index([book, chapter, verse])
  @@index([isActive, isFeatured])
  @@index([displayDate])
  @@map("bible_verses")
}

model VerseOfTheDay {
  id        String       @id @default(cuid())
  verseId   String
  date      DateTime     @unique
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  verse     BibleVerse   @relation(fields: [verseId], references: [id], onDelete: Cascade)
  shares    VerseShare[]

  @@index([date, isActive])
  @@map("verse_of_the_day")
}

model VerseShare {
  id              String         @id @default(cuid())
  verseId         String
  verseOfTheDayId String?
  shareType       String
  platform        String?
  recipientEmail  String?
  shareUrl        String?
  ipAddress       String?
  userAgent       String?
  isSuccessful    Boolean        @default(true)
  createdAt       DateTime       @default(now())
  verse           BibleVerse     @relation(fields: [verseId], references: [id], onDelete: Cascade)
  verseOfTheDay   VerseOfTheDay? @relation(fields: [verseOfTheDayId], references: [id], onDelete: Cascade)

  @@index([verseId, createdAt])
  @@index([shareType, createdAt])
  @@map("verse_shares")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  settings  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("newsletter_subscribers")
}

model Media {
  id           String   @id @default(cuid())
  filename     String   @unique
  originalName String
  mimeType     String
  size         Int
  url          String?  // Cloudinary secure URL
  publicId     String?  // Cloudinary public ID for management/deletion
  folder       String   // 'images' or 'videos'
  createdAt    DateTime @default(now())

  @@index([filename])
  @@map("media")
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@map("likes")
}

model SavedVerse {
  id        String     @id @default(cuid())
  userId    String
  verseId   String
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  verse     BibleVerse @relation(fields: [verseId], references: [id], onDelete: Cascade)

  @@unique([userId, verseId])
  @@map("saved_verses")
}
